# ============================================================
# Binjwa IT Solutions — Next.js Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# --- API Base URL (Backend / HRMS server) ---
# This is the CloudFront URL used for jobs, blogs, and applicants API
NEXT_PUBLIC_API_BASE_URL=https://dh8ut0pnb37w5.cloudfront.net/hrms

# --- Contact Form Email (Nodemailer SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
# Use an App Password (not your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password-here
CONTACT_EMAIL=binjwaitsolutions@gmail.com
